# Shared auth between host and pi callback APIs
OSU_PI_TOKEN=replace-with-shared-token

# Host service runtime
OSU_REPO_PATH=/Users/you/path/to/repo
OSU_CODEX_CMD=codex exec
OSU_COMMIT_STRATEGY=agent_multi
OSU_PROMPT_TEMPLATE=prompts/agent_commit_session_prompt.txt
OSU_PROJECT_CONTEXT_FILE=prompts/project_context.txt
OSU_PROJECT_CONTEXT_MAX_CHARS=4000
OSU_DIFF_MAX_CHARS=12000
OSU_COMMIT_TIMEOUT_SECONDS=180
OSU_PUSH_TIMEOUT_SECONDS=180
OSU_HOST_BIND=0.0.0.0
OSU_HOST_PORT=5000

# Host -> Pi commit status callback
OSU_PI_STATUS_URL=http://pi.local:5001/status/commit
OSU_CALLBACK_TIMEOUT_SECONDS=2.0
OSU_CALLBACK_RETRIES=2
OSU_CALLBACK_BACKOFF_SECONDS=0.2

# Host local speaker sounds (WAV)
OSU_LOCAL_AUDIO_ENABLED=1
OSU_LOCAL_AUDIO_PLAYER=
OSU_LOCAL_SOUND_BASE_DIR=/Users/you/Projects/wrdn/sounds
OSU_LOCAL_SOUND_NOTIFY_WAV=/Users/you/Projects/wrdn/sounds/notify.wav
OSU_LOCAL_SOUND_SUCCESS_WAV=/Users/you/Projects/wrdn/sounds/success.wav
OSU_LOCAL_SOUND_ERROR_WAV=/Users/you/Projects/wrdn/sounds/error.wav

# Pi -> Host button forwarding
OSU_HOST_BUTTON_URL=http://your-computer.local:5000/button/press
OSU_HOST_NOTIFY_URL=http://your-computer.local:5000/notify/codex
OSU_HOST_TOKEN=
OSU_HOST_TIMEOUT_SECONDS=2.0
OSU_HOST_RETRIES=2
OSU_HOST_BACKOFF_SECONDS=0.2

# Pi notify de-duplication / debounce
OSU_NOTIFY_MIN_INTERVAL_MS=250
OSU_NOTIFY_DEDUPE_BUCKET_MS=1000
OSU_NOTIFY_DEDUPE_RING_SIZE=512
OSU_BUTTON_MIN_INTERVAL_MS=1000
OSU_BUTTON_GPIO_PIN=23
OSU_BUTTON_GPIO_PULL=up
OSU_BUTTON_GPIO_EDGE=falling
OSU_BUTTON_BOUNCETIME_MS=150
OSU_LED_GPIO_PIN=25
# Optional RGB LED pins (set all three or leave blank)
OSU_LED_RED_PIN=
OSU_LED_GREEN_PIN=
OSU_LED_BLUE_PIN=
OSU_PI_BIND=0.0.0.0
OSU_PI_PORT=5001

# codex-notify-chime runtime (Rust)
OSU_NOTIFY_MODE=http
OSU_NOTIFY_URL=http://localhost:5000/notify/codex
OSU_NOTIFY_TOKEN=replace-with-shared-token
OSU_NOTIFY_TIMEOUT_MS=800
OSU_NOTIFY_RETRIES=2
OSU_NOTIFY_BACKOFF_MS=150
